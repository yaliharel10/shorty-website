generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                 String    @id @default(cuid())
  username           String    @unique
  displayName        String?
  email              String    @unique
  password           String?
  googleId           String?   @unique
  emailVerified      Boolean   @default(false)
  emailVerificationToken       String?   @unique
  emailVerificationExpiresAt   DateTime?
  onboardingCompleted          Boolean   @default(false)
  photoUrl           String?
  role               String    @default("user")
  subscriptionTier         String    @default("none")
  subscriptionStatus       String?
  subscriptionEndsAt       DateTime?
  trialEndsAt              DateTime?
  stripeCustomerId         String?   @unique
  stripeSubscriptionId     String?   @unique
  passwordResetToken       String?   @unique
  passwordResetExpiresAt DateTime?
  autoplayNext             Boolean   @default(true)
  playbackSpeed            Float     @default(1)
  subtitleLanguage         String    @default("en")
  reduceMotionPref         Boolean   @default(false)
  createdAt              DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  favorites Favorite[]
  ratings   Rating[]
  views     ViewEvent[]
  sessions  UserSession[]
  watchProgress WatchProgress[]
  profiles  Profile[]
  notifications Notification[]
  playbackSessions PlaybackSession[]
}

model UserSession {
  id           String   @id @default(cuid())
  userId       String
  tokenId      String   @unique
  deviceLabel  String
  userAgent    String?
  ipAddress    String?
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())
  expiresAt    DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Film {
  id               String   @id @default(cuid())
  title            String
  description      String
  category         String
  genres           String   @default("[]")
  moods            String   @default("[]")
  tags             String   @default("[]")
  language         String   @default("en")
  country          String?
  rating           Float    @default(0)
  posterUrl        String
  videoUrl         String
  featured         Boolean  @default(false)
  published        Boolean  @default(true)
  trendingScore    Float    @default(0)
  monthlyFreeMonth String?
  duration         Int      @default(15)
  kidsFriendly     Boolean  @default(true)
  year             Int      @default(2024)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  credits   FilmCredit[]
  favorites Favorite[]
  ratings   Rating[]
  views     ViewEvent[]
  watchProgress WatchProgress[]
  collections CollectionFilm[]
  playbackSessions PlaybackSession[]
}

model Person {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  bio         String
  longBio     String
  imgUrl      String
  primaryRole String
  birthplace  String?
  bornYear    Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  credits FilmCredit[]
}

model FilmCredit {
  id            String  @id @default(cuid())
  personId      String
  filmId        String
  role          String
  characterName String?

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  film   Film   @relation(fields: [filmId], references: [id], onDelete: Cascade)

  @@unique([personId, filmId, role])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  filmId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  film      Film     @relation(fields: [filmId], references: [id], onDelete: Cascade)

  @@unique([userId, filmId])
}

model Rating {
  id        String   @id @default(cuid())
  userId    String
  filmId    String
  score     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  film      Film     @relation(fields: [filmId], references: [id], onDelete: Cascade)

  @@unique([userId, filmId])
}

model ViewEvent {
  id           String   @id @default(cuid())
  userId       String?
  filmId       String
  watchSeconds Int      @default(0)
  createdAt    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  film         Film     @relation(fields: [filmId], references: [id], onDelete: Cascade)

  @@index([filmId, createdAt])
}

model WatchProgress {
  id              String   @id @default(cuid())
  userId          String
  filmId          String
  progressPercent Int      @default(0)
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  film            Film     @relation(fields: [filmId], references: [id], onDelete: Cascade)

  @@unique([userId, filmId])
  @@index([userId])
}

model Collection {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  heroUrl     String?
  featured    Boolean  @default(false)
  country     String?
  mood        String?
  sortOrder   Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  films CollectionFilm[]

  @@index([featured, sortOrder])
}

model CollectionFilm {
  collectionId String
  filmId       String
  sortOrder    Int @default(0)

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  film       Film       @relation(fields: [filmId], references: [id], onDelete: Cascade)

  @@id([collectionId, filmId])
  @@index([collectionId, sortOrder])
}

model Profile {
  id        String   @id @default(cuid())
  userId    String
  name      String
  avatarUrl String?
  isKids    Boolean  @default(false)
  pinHash   String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  href      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
}

model PlatformSettings {
  id                 String   @id @default("default")
  creatorPoolPercent Float    @default(50)
  updatedAt          DateTime @updatedAt
}

model PlaybackSession {
  id           String   @id @default(cuid())
  userId       String
  filmId       String
  sessionToken String   @unique
  lastActiveAt DateTime @default(now())
  expiresAt    DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  film         Film     @relation(fields: [filmId], references: [id], onDelete: Cascade)

  @@index([userId, lastActiveAt])
}
