# Copy to .env and fill in values before running in production

# Local SQLite (default for development)
DATABASE_URL="file:./dev.db"

# Production on Vercel — Turso serverless SQLite (free, always on)
# Create at https://turso.tech then: turso db create shorty
# TURSO_DATABASE_URL="libsql://shorty-yourorg.turso.io"
# TURSO_AUTH_TOKEN="..."

# REQUIRED in production — use a long random string (32+ chars)
JWT_SECRET="change-me-to-a-long-random-secret"

# Public site URL for sitemap/metadata, Stripe return URLs, password reset links
# NEXT_PUBLIC_SITE_URL="https://your-app.vercel.app"

# Set true only on Render free tier (server sleeps — login needs wake-up retries)
# Leave unset on Vercel for instant login
# NEXT_PUBLIC_SLOW_HOST="true"

# Optional: send password reset emails via Resend (https://resend.com)
# Without this, reset links are logged to the server console in development.
# RESEND_API_KEY="re_..."
# EMAIL_FROM="Shorty <noreply@your-domain.com>"

# Stripe — required for live subscriptions (https://stripe.com)
# Test keys start with sk_test_ / pk_test_
# STRIPE_SECRET_KEY="sk_test_..."
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."  # from Stripe webhook endpoint

# Test page one-click login (/test) — set true on Render for demo access
# ENABLE_TEST_LOGIN="true"
