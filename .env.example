# Copy to .env and fill in values before running in production

# SQLite database file (default works for local development)
DATABASE_URL="file:./dev.db"

# REQUIRED in production — use a long random string (32+ chars)
JWT_SECRET="change-me-to-a-long-random-secret"

# Optional: public site URL for sitemap/metadata and password reset links
# NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# Optional: send password reset emails via Resend (https://resend.com)
# Without this, reset links are logged to the server console in development.
# RESEND_API_KEY="re_..."
# EMAIL_FROM="Shorty <noreply@your-domain.com>"

# Stripe — required for live subscriptions (https://stripe.com)
# Test keys start with sk_test_ / pk_test_
# STRIPE_SECRET_KEY="sk_test_..."
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."  # from Stripe webhook endpoint

# Test page one-click login (/test) — set true on Render for demo access
# ENABLE_TEST_LOGIN="true"
