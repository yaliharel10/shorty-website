# Copy to .env and fill in values before running in production

# Local SQLite (default for development)
DATABASE_URL="file:./dev.db"

# Production on Vercel — Turso serverless SQLite
# TURSO_DATABASE_URL="libsql://shorty-yourorg.turso.io"
# TURSO_AUTH_TOKEN="..."

# REQUIRED in production
JWT_SECRET="change-me-to-a-long-random-secret"
NEXT_PUBLIC_SITE_URL="https://your-app.vercel.app"

# REQUIRED in production — Stripe live or test keys
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# REQUIRED in production — transactional email
RESEND_API_KEY="re_..."
EMAIL_FROM="Shorty <noreply@your-domain.com>"

# Production admin (first deploy only — change password after login)
ADMIN_INITIAL_PASSWORD="use-a-strong-random-password"
ADMIN_EMAIL="admin@your-domain.com"

# Google OAuth (optional but recommended)
# GOOGLE_CLIENT_ID="..."
# GOOGLE_CLIENT_SECRET="..."

# Dev only — demo users and /test routes (NEVER true in production)
# SEED_DEMO_USERS="true"
# ENABLE_TEST_LOGIN="true"

# Optional: error tracking
# SENTRY_DSN="https://..."

# Optional: Upstash Redis for distributed rate limiting
# UPSTASH_REDIS_REST_URL="https://..."
# UPSTASH_REDIS_REST_TOKEN="..."

# Optional: analytics
# POSTHOG_API_KEY="phc_..."
# POSTHOG_HOST="https://us.i.posthog.com"
